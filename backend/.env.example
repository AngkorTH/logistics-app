# ---- Database ----
# สำหรับ dev แบบเร็ว ใช้ SQLite ได้เลย (ไม่ต้องตั้ง PostgreSQL):
#   DATABASE_URL=sqlite:///./logistics.db
# สำหรับ production ใช้ PostgreSQL:
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/logistics_erp

# ---- Auth (ใช้ใน Step 1 ส่วนที่ 2) ----
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

# ---- App ----
DEBUG=true
